services:
{%- if 'backend' in modules %}
  backend:
    extends:
      file: compose.base.yml
      service: backend
    build:
      context: ..
      dockerfile: services/backend/Dockerfile
      args:
        INSTALL_DEV_DEPS: ${BACKEND_INSTALL_DEV_DEPS:-false}
    command: >-
      bash -c "./services/backend/scripts/migrate.sh &&
      uvicorn services.backend.src.main:app --host 0.0.0.0 --port 8000 --reload"
    volumes:
      - ../:/workspace:delegated
    working_dir: /workspace
    env_file:
      - ../.env
    environment:
      PYTHONPATH: /workspace
      PATH: /workspace/services/backend/.venv/bin:/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin
{%- endif %}
{%- if 'tg_bot' in modules %}
  tg_bot:
{%- if 'backend' in modules %}
    profiles: ["tg"]
{%- endif %}
    extends:
      file: compose.base.yml
      service: tg_bot
    volumes:
      - ../:/workspace:delegated
    working_dir: /workspace
    env_file:
      - ../.env
    environment:
      PYTHONPATH: /workspace
      PATH: /workspace/services/tg_bot/.venv/bin:/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin
{%- endif %}
{%- if 'notifications' in modules %}
  notifications_worker:
    extends:
      file: compose.base.yml
      service: notifications_worker
    volumes:
      - ../:/workspace:delegated
    working_dir: /workspace
    env_file:
      - ../.env
    environment:
      PYTHONPATH: /workspace
      PATH: /workspace/services/notifications_worker/.venv/bin:/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin
{%- endif %}
{%- if 'backend' in modules %}

  db:
    extends:
      file: compose.base.yml
      service: db
    ports:
      - "${POSTGRES_HOST_PORT:-5432}:5432"
{%- endif %}
{%- if 'tg_bot' in modules or 'notifications' in modules %}

  redis:
    extends:
      file: compose.base.yml
      service: redis
    ports:
      - "${REDIS_HOST_PORT:-6379}:6379"
{%- endif %}
