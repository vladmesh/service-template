version: "1"
owner: infra
entries:
{% if 'backend' in modules %}
  POSTGRES_HOST_PORT:
    source: literal
    environments: [local]
    required: true
    value: 5432
{% endif %}
{% if 'backend' in modules or 'tg_bot' in modules or 'notifications' in modules %}
  REDIS_HOST_PORT:
    source: literal
    environments: [local]
    required: true
    value: 6379
  REDIS_URL:
    source: literal
    environments: [local, production]
    consumers: [{{ ((['backend'] if 'backend' in modules else []) + (['tg_bot'] if 'tg_bot' in modules else []) + (['notifications_worker'] if 'notifications' in modules else [])) | join(', ') }}]
    required: true
    value: redis://redis:6379
{% endif %}
