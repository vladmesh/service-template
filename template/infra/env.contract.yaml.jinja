version: "1"
owner: infra
entries:
  ENVIRONMENT:
    source: literal
    environments: [local, production]
    required: true
    value: development
  DEBUG:
    source: literal
    environments: [local]
    required: true
    value: true
  APP_NAME:
    source: derived
    environments: [local, production]
    required: true
  APP_ENV:
    source: literal
    environments: [local, production]
    required: true
    value: development
  APP_SECRET_KEY:
    source: generated_secret
    environments: [local, production]
    required: true
{% if 'backend' in modules %}  BACKEND_PORT:
    source: allocation
    environments: [local, production]
    consumers: [backend]
    required: true
    service: backend
  POSTGRES_HOST_PORT:
    source: literal
    environments: [local]
    required: true
    value: 5432
{% endif %}{% if 'backend' in modules or 'tg_bot' in modules or 'notifications' in modules %}  REDIS_HOST_PORT:
    source: literal
    environments: [local]
    required: true
    value: 6379
  REDIS_URL:
    source: generated_secret
    environments: [local, production]
    consumers: [{% if 'backend' in modules %}backend{% if 'tg_bot' in modules or 'notifications' in modules %}, {% endif %}{% endif %}{% if 'tg_bot' in modules %}tg_bot{% if 'notifications' in modules %}, {% endif %}{% endif %}{% if 'notifications' in modules %}notifications_worker{% endif %}]
    required: true
{% endif %}{% if 'backend' in modules %}  BACKEND_IMAGE:
    source: derived
    environments: [local, production]
    consumers: [backend]
    required: true
{% endif %}{% if 'tg_bot' in modules %}  TG_BOT_IMAGE:
    source: derived
    environments: [local, production]
    consumers: [tg_bot]
    required: true
{% endif %}{% if 'notifications' in modules %}  NOTIFICATIONS_WORKER_IMAGE:
    source: derived
    environments: [local, production]
    consumers: [notifications_worker]
    required: true
{% endif %}{% if 'frontend' in modules %}  FRONTEND_IMAGE:
    source: derived
    environments: [local, production]
    consumers: [frontend]
    required: true
  FRONTEND_PORT:
    source: allocation
    environments: [local, production]
    consumers: [frontend]
    required: true
    service: frontend
{% endif %}
