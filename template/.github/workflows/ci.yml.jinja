name: CI

on:
  push:
    branches:
      - main
  pull_request:
    branches:
      - main
  workflow_dispatch:

env:
  DOCKER_BUILDKIT: "1"

jobs:
  lint-and-test:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Python {{ python_version }}
        uses: actions/setup-python@v5
        with:
          python-version: "{{ python_version }}"

      - name: Set up uv
        uses: astral-sh/setup-uv@v4

      - name: Set up project
        run: make setup

      - name: Prepare environment files
        run: |
          cp .env.example .env
          if [ ! -f infra/.env.test ]; then
            echo "infra/.env.test missing" >&2
            exit 1
          fi
{% if 'backend' in modules %}
      - name: Generate from spec
        run: make generate-from-spec

      - name: Check generated files are up to date
        run: git diff --exit-code -- shared/shared/generated/ services/*/src/generated/
{% endif %}
      - name: Run linters
        run: make lint

      - name: Run tests
        run: make tests
{% if 'backend' in modules %}
      - name: Run integration tests
        run: make test-integration

      - name: Clean up
        if: always()
        run: |
          COMPOSE_PROJECT_NAME=tests-integration docker compose -f infra/compose.tests.integration.yml down --volumes --remove-orphans 2>/dev/null || true
{% endif %}

  build-and-push:
    runs-on: ubuntu-latest
    needs: lint-and-test
    if: {% raw %}${{ github.event_name == 'push' && github.ref == 'refs/heads/main' }}{% endraw %}
    strategy:
      matrix:
        include:
          {% if 'backend' in modules %}
          - id: backend
            context: .
            dockerfile: services/backend/Dockerfile
            image-suffix: backend
          {% endif %}
          {% if 'frontend' in modules %}
          - id: frontend
            context: services/frontend
            dockerfile: services/frontend/Dockerfile
            image-suffix: frontend
          {% endif %}
          {% if 'tg_bot' in modules %}
          - id: tg-bot
            context: .
            dockerfile: services/tg_bot/Dockerfile
            image-suffix: tg-bot
          {% endif %}
          {% if 'notifications' in modules %}
          - id: notifications-worker
            context: .
            dockerfile: services/notifications_worker/Dockerfile
            image-suffix: notifications-worker
          {% endif %}
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Prepare .env placeholder
        run: cp .env.example .env
{% if 'backend' in modules %}
      - name: Set up Python {{ python_version }}
        uses: actions/setup-python@v5
        with:
          python-version: "{{ python_version }}"

      - name: Set up uv
        uses: astral-sh/setup-uv@v4

      - name: Generate code from specs
        run: |
          uv venv
          uv pip install -e .framework/ ruff
          make generate-from-spec
{% endif %}
      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Log in to Docker Registry
        run: |
          for attempt in 1 2 3; do
            echo "Docker login attempt $attempt/3"
            if echo "{% raw %}${{ secrets.REGISTRY_PASSWORD }}{% endraw %}" | docker login \
              "{% raw %}${{ secrets.REGISTRY_URL }}{% endraw %}" \
              --username "{% raw %}${{ secrets.REGISTRY_USER }}{% endraw %}" \
              --password-stdin; then
              echo "Docker login succeeded"
              exit 0
            fi
            if [ "$attempt" -lt 3 ]; then
              wait=$((attempt * 10 - 5))
              echo "Docker login failed, retrying in ${wait}s..."
              sleep $wait
            fi
          done
          echo "Docker login failed after 3 attempts"
          exit 1

      - name: Extract metadata (tags, labels) for Docker
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: {% raw %}${{ secrets.REGISTRY_URL }}/${{ github.repository }}-${{ matrix.image-suffix }}{% endraw %}
          tags: |
            type=raw,value=latest,enable={% raw %}${{ github.ref == 'refs/heads/main' }}{% endraw %}
            type=sha

      - name: Build and push {% raw %}${{ matrix.id }}{% endraw %}
        uses: docker/build-push-action@v5
        with:
          context: {% raw %}${{ matrix.context }}{% endraw %}
          file: {% raw %}${{ matrix.dockerfile }}{% endraw %}
          push: true
          provenance: false
          tags: {% raw %}${{ steps.meta.outputs.tags }}{% endraw %}
          labels: {% raw %}${{ steps.meta.outputs.labels }}{% endraw %}
