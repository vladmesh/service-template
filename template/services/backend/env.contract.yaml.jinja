version: "1"
owner: backend
entries:
  BACKEND_PORT:
    source: allocation
    environments: [local, production]
    consumers: [backend]
    required: true
    service: backend
  BACKEND_IMAGE:
    source: derived
    environments: [local, production]
    consumers: [backend]
    required: true
  POSTGRES_HOST:
    source: literal
    environments: [local, production]
    consumers: [backend]
    required: true
    value: db
  POSTGRES_PORT:
    source: literal
    environments: [local, production]
    consumers: [backend]
    required: true
    value: 5432
  POSTGRES_DB:
    source: derived
    environments: [local, production]
    consumers: [backend]
    required: true
  POSTGRES_USER:
    source: literal
    environments: [local, production]
    consumers: [backend]
    required: true
    value: postgres
  POSTGRES_PASSWORD:
    source: generated_secret
    environments: [local, production]
    consumers: [backend]
    required: true
  POSTGRES_REQUIRE_SSL:
    source: literal
    environments: [local, production]
    consumers: [backend]
    required: true
    value: false
{% if 'tg_bot' in modules or 'notifications' in modules %}
  BACKEND_API_URL:
    source: literal
    environments: [local, production]
    consumers: [{{ ((['tg_bot'] if 'tg_bot' in modules else []) + (['notifications_worker'] if 'notifications' in modules else [])) | join(', ') }}]
    required: true
    value: http://backend:8000
{% endif %}
