version: "1"
owner: backend
entries:
  POSTGRES_HOST:
    source: literal
    environments: [local, production]
    consumers: [backend]
    required: true
    value: db
  POSTGRES_PORT:
    source: literal
    environments: [local, production]
    consumers: [backend]
    required: true
    value: 5432
  POSTGRES_DB:
    source: derived
    environments: [local, production]
    consumers: [backend]
    required: true
  POSTGRES_USER:
    source: literal
    environments: [local, production]
    consumers: [backend]
    required: true
    value: postgres
  POSTGRES_PASSWORD:
    source: generated_secret
    environments: [local, production]
    consumers: [backend]
    required: true
  POSTGRES_REQUIRE_SSL:
    source: literal
    environments: [local, production]
    consumers: [backend]
    required: true
    value: false
{% if 'tg_bot' in modules or 'notifications' in modules %}  BACKEND_API_URL:
    source: literal
    environments: [local, production]
    consumers: [{% if 'tg_bot' in modules %}tg_bot{% if 'notifications' in modules %}, {% endif %}{% endif %}{% if 'notifications' in modules %}notifications_worker{% endif %}]
    required: true
    value: http://backend:8000
{% endif %}
