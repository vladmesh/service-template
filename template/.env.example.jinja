# {{ project_name }} Environment Configuration
# Copy this file to .env and adjust values as needed

# Common settings
ENVIRONMENT=development
DEBUG=true

# Application
APP_NAME={{ project_name }}
APP_ENV=development
APP_SECRET_KEY=please-change-me-in-production

# Set a unique Compose project name when running multiple generated projects
# on the same Docker host.
# COMPOSE_PROJECT_NAME={{ project_slug }}-dev
{%- if 'backend' in modules %}

# Backend host port (mapped to container's 8000)
BACKEND_PORT=8000

# Database (PostgreSQL)
POSTGRES_HOST_PORT=5432
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB={{ project_slug }}
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_REQUIRE_SSL=false
{%- endif %}
{%- if 'backend' in modules or 'tg_bot' in modules or 'notifications' in modules %}

# Redis (for async messaging)
REDIS_HOST_PORT=6379
REDIS_URL=redis://redis:6379
{%- endif %}
{%- if 'backend' in modules and ('tg_bot' in modules or 'notifications' in modules) %}

# Backend API URL (for service-to-service communication)
BACKEND_API_URL=http://backend:8000
{%- endif %}
{%- if 'tg_bot' in modules %}

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
{%- endif %}

# Docker images (for production compose)
{%- if 'backend' in modules %}
BACKEND_IMAGE={{ project_slug }}-backend:latest
{%- endif %}
{%- if 'tg_bot' in modules %}
TG_BOT_IMAGE={{ project_slug }}-tg:latest
{%- endif %}
{%- if 'notifications' in modules %}
NOTIFICATIONS_WORKER_IMAGE={{ project_slug }}-notifications:latest
{%- endif %}
{%- if 'frontend' in modules %}
FRONTEND_IMAGE={{ project_slug }}-frontend:latest
FRONTEND_PORT=3000
{%- endif %}
